@model List<MoviesManager.Models.Movie>

<!-- Adding styling using style attribute -->
<style>
    body {
        font-family: Arial, sans-serif;
        background-color:#cce7ff; 
        color:#1c1b18; 
        padding: 20px;
    }  
    
    .header-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 20px;
    }

    .header-container h2 {
        margin: 0;
        color: #007bff;
        font-weight: 900;  
        font-size: 2em;    
    }

    .header-container a.add-btn {
        margin-top: 10px;
    }

    h2 { color: #007bff; }

    a.add-btn {
        display: inline-block;
        margin-bottom: 15px;
        padding: 6px 10px;
        background-color: #007bff;
        color: #f5f5dc;
        text-decoration: none;
        border-radius: 4px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

    th, td {
        padding: 8px;
        border-bottom: 1px solid #444;
    }

    th { text-align: left; }

    a.action-link {
        color: red;
        text-decoration: none;
    }

    a.add-btn,
    button {
        transition: all 0.3s ease;
        box-shadow: 0 3px 6px rgba(0, 0, 0, 0.2);

    }

    a.add-btn:hover,
    button:hover {
        background-color: #0056b3; 
        color: #fff;               
        transform: scale(1.05);    
        box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
    }
</style>
<!-- I added some hover and shadow effect for better UI experience beacuse I love to play with CSS!!!! -->


<div class = "header-container">
    <h2> Movies List</h2>
    <a href="/Movies/Create" class="add-btn">Add New Movie</a>
</div>

<table>
    <tr>
        <th>Title</th>
        <th>Director</th>
        <th>Genre</th>
        <th>Year</th>
        <th>Rating</th>
        <th>Actions</th>
    </tr>

@foreach (var movie in Model)
{
    <tr>
        <td>@movie.Title</td>
        <td>@movie.Director</td>
        <td>@movie.Genre</td>
        <td>@movie.Year</td>
        <td>@movie.Rating</td>
        <td>
            <a href="/Movies/Edit/@movie.Id" class="action-link">Edit</a> |
            <a href="/Movies/Delete/@movie.Id" class="action-link">Delete</a>
        </td>
    </tr>
}
</table>
